# =============================================================================
# FLOE — Environment Variables
# =============================================================================
# Salin file ini ke .env lalu isi nilai sesuai punya kamu.
# .env SUDAH ada di .gitignore — tidak akan pernah ke-commit.
# =============================================================================

# ---------------------------------------------------------------------------
# TELEGRAM
# ---------------------------------------------------------------------------

# Token bot dari @BotFather di Telegram.
# Wajib. Bot tidak bisa jalan tanpa ini.
TELEGRAM_BOT_TOKEN=123456789:contohTokenDariBotFather

# Whitelist: daftar Telegram user ID yang diizinkan pakai bot.
# Wajib. User di luar daftar ini akan ditolak.
# Format: pisahkan dengan koma jika lebih dari satu user.
# Contoh: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=123456789

# ---------------------------------------------------------------------------
# GEMINI AI
# ---------------------------------------------------------------------------

# API key dari Google AI Studio (https://aistudio.google.com).
# Wajib. Dipakai untuk parsing transaksi dari teks dan foto.
GEMINI_API_KEY=contohApiKeyDariGoogleAiStudio

# Nama model Gemini yang dipakai.
# Opsional. Default: gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash-lite

# ---------------------------------------------------------------------------
# GOOGLE SHEETS
# ---------------------------------------------------------------------------

# ID spreadsheet dari URL Google Sheets.
# Wajib. Bot membaca dan menulis transaksi ke spreadsheet ini.
# Cara dapat: buka spreadsheet -> ambil ID dari URL
# Contoh URL: https://docs.google.com/spreadsheets/d/ABSBD12xxx/edit
SPREADSHEET_ID=contohSpreadsheetId

# Path ke file JSON service account Google.
# Opsional. Default: service_account.json (di root proyek)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ---------------------------------------------------------------------------
# WEBHOOK (opsional — fallback ke polling jika tidak diset)
# ---------------------------------------------------------------------------

# URL publik untuk webhook (dari Railway, tunnel, atau server pribadi).
# Jika diset, bot akan menggunakan webhook; jika tidak, polling.
# Tidak perlu diset jika jalan lokal 24/7.
# WEBHOOK_URL=https://example.com

# Secret token untuk verifikasi webhook dari Telegram.
# Sangat direkomendasikan jika webhook aktif.
# WEBHOOK_SECRET=kataRahasia

# Port untuk webhook server.
# Railway otomatis menyetel PORT. Ganti hanya jika perlu.
# Default: 8080
PORT=8080

# ---------------------------------------------------------------------------
# SCHEDULER (opsional — pakai nilai default jika tidak diset)
# ---------------------------------------------------------------------------

# Jam pengiriman ringkasan harian (HH:MM, zona WIB).
# Opsional. Default: 21:00
DAILY_SUMMARY_TIME=21:00

# Hari pengiriman ringkasan mingguan (nama hari bahasa Inggris).
# Opsional. Default: sunday
WEEKLY_SUMMARY_DAY=sunday

# Jam pengiriman ringkasan mingguan (HH:MM, zona WIB).
# Opsional. Default: 20:00
WEEKLY_SUMMARY_TIME=20:00
